#!/bin/zsh

set -u

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
if [[ -z "${repo_root}" ]]; then
  echo "pre-commit: unable to determine repository root" >&2
  exit 1
fi

cd "${repo_root}" || exit 1

added_sources="$(git diff --cached --name-only --diff-filter=A -- sources/)"
if [[ -z "${added_sources}" ]]; then
  exit 0
fi

if ! command -v codex >/dev/null 2>&1; then
  echo "pre-commit: new files were added under sources/, but codex is not on PATH" >&2
  echo "pre-commit: run Codex manually for these files, then retry the commit:" >&2
  echo "${added_sources}" >&2
  exit 1
fi

echo "pre-commit: new files detected under sources/:"
echo "${added_sources}"
echo
echo "pre-commit: running Codex source ingest review..."

prompt=$(
  cat <<PROMPT
New files were added under sources/:

${added_sources}

Review them in this investment research wiki repository. Create or update source summaries beside the source material, update wiki/index.md and wiki/log.md if needed, and leave any changes unstaged for human review. Follow AGENTS.md. Do not commit.
PROMPT
)

codex exec --cd "${repo_root}" "${prompt}"
codex_status=$?

echo
echo "pre-commit: Codex finished with status ${codex_status}."
echo "pre-commit: current working tree:"
git status --short
echo

if [[ ${codex_status} -ne 0 ]]; then
  echo "pre-commit: Codex failed. Review the output above before committing." >&2
  exit ${codex_status}
fi

echo "pre-commit: blocking this commit so you can review and stage Codex-generated changes."
echo "pre-commit: after review, stage the intended files and run git commit again."
exit 1
