#!/bin/zsh

set -u

if [[ "${LLM_WIKI_SOURCE_REVIEW:-}" == "1" ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
if [[ -z "${repo_root}" ]]; then
  echo "post-commit: unable to determine repository root" >&2
  exit 0
fi

cd "${repo_root}" || exit 0

added_sources="$(git diff-tree --no-commit-id --name-only --diff-filter=A -r HEAD -- sources/)"
if [[ -z "${added_sources}" ]]; then
  exit 0
fi

if ! command -v codex >/dev/null 2>&1; then
  echo "post-commit: new files were committed under sources/, but codex is not on PATH" >&2
  echo "post-commit: run Codex manually for these files:" >&2
  echo "${added_sources}" >&2
  exit 0
fi

echo "post-commit: new files committed under sources/:"
echo "${added_sources}"
echo
echo "post-commit: running Codex source ingest review..."

prompt=$(
  cat <<PROMPT
New files were committed under sources/:

${added_sources}

Review them in this investment research wiki repository. Create or update source summaries beside the source material, update wiki/index.md and wiki/log.md if needed, and leave any changes unstaged for human review in a follow-up commit. Follow AGENTS.md. Do not amend, revert, or create commits.
PROMPT
)

LLM_WIKI_SOURCE_REVIEW=1 codex exec --cd "${repo_root}" "${prompt}"
codex_status=$?

echo
echo "post-commit: Codex finished with status ${codex_status}."
echo "post-commit: current working tree:"
git status --short
echo

if [[ ${codex_status} -ne 0 ]]; then
  echo "post-commit: Codex failed. Review the output above and run the ingest review manually if needed." >&2
fi

exit 0
