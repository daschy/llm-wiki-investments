{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh \"$(git rev-parse --show-toplevel)/.codex/hooks/load-llm-wiki.zsh\"",
            "timeout": 10,
            "statusMessage": "Loading llm-wiki"
          }
        ]
      }
    ]
  }
}
